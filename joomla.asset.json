{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "itheme",
  "version": "1.0.35",
  "description": "This file contains details of the assets used by Cassiopeia, the default Joomla site template.",
  "license": "GPL-2.0-or-later",
  "assets": [
    {
      "name": "tpl.itheme",
      "description": "Основная таблица стилей, необходима для всех страниц",
      "type": "style",
      "uri": "itheme.min.css"
    },
    {
      "name": "tpl.lazyload",
      "description": "Основной файл скриптов для данного шаблона",
      "type": "script",
      "uri": "lazyload.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.analytics",
      "description": "Отслеживание событий для систем аналитики",
      "type": "script",
      "uri": "analytics.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.google",
      "description": "Локальный файл счетчика Google Аналитики",
      "type": "script",
      "uri": "google.js",
      "attributes" : {
        "async": true
      }
    },
    {
      "name": "tpl.yandex",
      "description": "Локальный файл счетчика Яндекс Метрики",
      "type": "script",
      "uri": "metrika.js",
      "attributes" : {
        "async": true
      }
    },
    {
      "name": "tpl.tiktok",
      "description": "Локальный файл пикселя TikTok",
      "type": "script",
      "uri": "tiktok.js",
      "attributes" : {
        "async": true
      }
    },
    {
      "name": "tpl.itheme",
      "description": "Основной файл скриптов для данного шаблона",
      "type": "script",
      "uri": "itheme.js",
      "attributes" : {
        "type": "module",
        "defer": true
      },
      "dependencies": [
        "core",
        "tpl.lazyload",
        "tpl.analytics",
        "tpl.drag-scroller"
      ]
    },
    {
      "name": "tpl.header-sticky",
      "description": "Скрипт для фиксации шапки сайта",
      "type": "script",
      "uri": "headersticky.js"
    },
    {
      "name": "tpl.offcanvas-slider",
      "description": "Скрипт вложенных панелей offcanvas",
      "type": "script",
      "uri": "offcanvas-slider.js",
      "dependencies": [
        "core",
        "bootstrap.offcanvas"
      ]
    },
    {
      "name": "tpl.phone-masker",
      "description": "Скрипт для маски телефона в полях input",
      "type": "script",
      "uri": "phone_masker.js"
    },
    {
      "name": "tpl.buy1click",
      "description": "Скрипт обновления модальной формы заказа в 1 клик",
      "type": "script",
      "uri": "buy1click.js"
    },
    {
      "name": "tpl.form-validate",
      "description": "Скрипт валидации полей формы",
      "type": "script",
      "uri": "form-validate.js"
    },
    {
      "name": "tpl.checkout",
      "description": "Скрипт подтверждения заказа",
      "type": "script",
      "uri": "checkout.js",
      "dependencies": [
        "core",
        "tpl.form-validate"
      ]
    },
    {
      "name": "tpl.submit",
      "description": "Скрипт отправки формы",
      "type": "script",
      "uri": "form-submit.js",
      "dependencies": [
        "tpl.form-validate"
      ]
    },
    {
      "name": "tpl.drag-scroller",
      "description": "Скрипт горизонтальной прокрутки элементов",
      "type": "script",
      "uri": "drag-scroller.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.gallery",
      "description": "Скрипт синхронизации миниатюр галереи",
      "type": "script",
      "uri": "gallery.js",
      "attributes" : {
        "defer": true
      },
      "dependencies": [
        "core",
        "bootstrap.carousel"
      ]
    }
  ]
}
