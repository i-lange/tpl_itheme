{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "itheme",
  "version": "1.0.47",
  "description": "This file contains details of the assets used by Cassiopeia, the default Joomla site template.",
  "license": "GPL-2.0-or-later",
  "assets": [
    {
      "name": "tpl.itheme",
      "description": "Основная таблица стилей, необходима для всех страниц",
      "type": "style",
      "uri": "itheme.min.css"
    },
    {
      "name": "tpl.lazyload",
      "description": "Основной файл скриптов для данного шаблона",
      "type": "script",
      "uri": "lazyload.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.itheme",
      "description": "Основной файл скриптов для данного шаблона",
      "type": "script",
      "uri": "itheme.js",
      "attributes" : {
        "type": "module",
        "defer": true
      },
      "dependencies": [
        "core",
        "tpl.lazyload",
        "tpl.drag-scroller"
      ]
    },
    {
      "name": "tpl.header-sticky",
      "description": "Скрипт для фиксации шапки сайта",
      "type": "script",
      "uri": "headersticky.js"
    },
    {
      "name": "tpl.offcanvas-slider",
      "description": "Скрипт вложенных панелей offcanvas",
      "type": "script",
      "uri": "offcanvas-slider.js",
      "dependencies": [
        "core",
        "bootstrap.offcanvas"
      ]
    },
    {
      "name": "tpl.phone-masker",
      "description": "Скрипт для маски телефона в полях input",
      "type": "script",
      "uri": "phone_masker.js"
    },
    {
      "name": "tpl.buy1click",
      "description": "Скрипт обновления модальной формы заказа в 1 клик",
      "type": "script",
      "uri": "buy1click.js"
    },
    {
      "name": "tpl.form-validate",
      "description": "Скрипт валидации полей формы",
      "type": "script",
      "uri": "form-validate.js"
    },
    {
      "name": "tpl.checkout",
      "description": "Скрипт подтверждения заказа",
      "type": "script",
      "uri": "checkout.js",
      "dependencies": [
        "core",
        "tpl.form-validate"
      ]
    },
    {
      "name": "tpl.submit",
      "description": "Скрипт отправки формы",
      "type": "script",
      "uri": "form-submit.js",
      "dependencies": [
        "tpl.form-validate"
      ]
    },
    {
      "name": "tpl.drag-scroller",
      "description": "Скрипт горизонтальной прокрутки элементов",
      "type": "script",
      "uri": "drag-scroller.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.warehouse-stock-filter",
      "description": "Фильтр товаров по категориям на странице магазина",
      "type": "script",
      "uri": "warehouse-stock-filter.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.compare-sticky",
      "description": "Фиксация панели товаров на странице сравнения",
      "type": "script",
      "uri": "compare-sticky.js",
      "attributes" : {
        "defer": true
      },
      "dependencies": [
        "tpl.drag-scroller"
      ]
    },
    {
      "name": "tpl.category-sticky-toolbar",
      "description": "Фиксация панели сортировки товаров в категории",
      "type": "script",
      "uri": "category-sticky-toolbar.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.litelight",
      "description": "Стили LiteLight для просмотра изображений в полноэкранном режиме",
      "type": "style",
      "uri": "litelight.min.css"
    },
    {
      "name": "tpl.litelight",
      "description": "Библиотека LiteLight для просмотра изображений в полноэкранном режиме",
      "type": "script",
      "uri": "vendor/litelight/lite-light.umd.min.js",
      "attributes" : {
        "defer": true
      }
    },
    {
      "name": "tpl.gallery",
      "description": "Скрипт синхронизации миниатюр галереи",
      "type": "script",
      "uri": "gallery.js",
      "attributes" : {
        "defer": true
      },
      "dependencies": [
        "core",
        "bootstrap.carousel"
      ]
    },
    {
      "name": "tpl.gallery-lightbox-init",
      "description": "Инициализация LiteLight для галерей шаблона",
      "type": "script",
      "uri": "gallery-lightbox.js",
      "attributes" : {
        "defer": true
      },
      "dependencies": [
        "core",
        "tpl.litelight"
      ]
    },
    {
      "name": "tpl.gallery-lightbox",
      "description": "Ассеты LiteLight для галерей шаблона",
      "type": "preset",
      "dependencies": [
        "tpl.litelight#style",
        "tpl.litelight#script",
        "tpl.gallery-lightbox-init#script"
      ]
    }
  ]
}
